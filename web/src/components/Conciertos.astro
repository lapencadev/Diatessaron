---
// Lista de conciertos — añade, edita o elimina entradas aquí
const conciertos = [
  {
    fechaISO: '2026-05-17',
    fechaTexto: 'Dom 17 de mayo',
    hora: 'Tras la misa de 12h',
    lugar: 'Parroquia San Isidro',
    ciudad: 'San Isidro · Alicante',
    entradas: null,
    cartel: '/images/carteles/cartel san isidro.jpg',
  },
  {
    fechaISO: '2026-05-19',
    fechaTexto: 'Mar 19 de mayo',
    hora: null,
    lugar: 'Iglesia Conventual de Santa Ana',
    ciudad: 'Murcia',
    entradas: null,
    cartel: null,
  },
  {
    fechaISO: '2026-05-30',
    fechaTexto: 'Sáb 30 de mayo',
    hora: '20:00 h',
    lugar: 'Auditorio Víctor Villegas',
    ciudad: 'Murcia',
    entradas: 'https://www.bacantix.com/Entradas/WebForms/Forms/Venta.aspx?id=AuMurcia&codigo=000002002000597002985',
    cartel: '/images/carteles/cartel auditorio.jpeg',
  },
];

const fechasJSON = JSON.stringify(conciertos.map(c => ({
  fechaISO: c.fechaISO,
  fechaTexto: c.fechaTexto,
  hora: c.hora,
  lugar: c.lugar,
  ciudad: c.ciudad,
})));
---

<!-- ─── Popup próximo concierto ─── -->
<div
  id="popup-concierto"
  role="dialog"
  aria-modal="true"
  aria-labelledby="popup-titulo"
  class="fixed inset-0 z-[60] hidden items-center justify-center p-4"
  style="background: rgba(8,8,8,0.82); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);"
>
  <div
    id="popup-panel"
    class="relative w-full max-w-sm border border-coro-gold/25 bg-coro-dark p-8"
    style="box-shadow: 0 0 60px -10px rgba(201,168,76,0.18);"
  >
    <button
      id="popup-cerrar"
      class="absolute top-4 right-4 text-coro-light/30 hover:text-coro-gold transition-colors"
      aria-label="Cerrar"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>

    <p class="text-coro-gold text-xs tracking-[0.3em] uppercase mb-5">Concierto próximo</p>
    <div id="popup-fecha-info" class="border-l border-coro-gold/25 pl-4 mb-7 space-y-0.5">
      <!-- Relleno por JS -->
    </div>
    <p class="text-coro-light/40 text-xs leading-relaxed mb-6">
      ¡No te lo pierdas! Consulta todos los detalles en la sección de conciertos.
    </p>
    <a href="#conciertos" id="popup-ir" class="btn-primary block text-center text-xs tracking-[0.2em] uppercase py-3 px-6">
      Ver conciertos
    </a>
  </div>
</div>

<!-- ─── Lightbox cartel ─── -->
<div
  id="modal-cartel"
  role="dialog"
  aria-modal="true"
  aria-label="Cartel del concierto"
  class="fixed inset-0 z-50 hidden items-center justify-center p-4 sm:p-8"
  style="background: rgba(8,8,8,0.90); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);"
>
  <div
    class="relative flex flex-col bg-coro-dark border border-coro-gold/15"
    style="max-width: min(560px, calc(100vw - 2rem)); max-height: calc(100vh - 4rem); box-shadow: 0 0 80px -10px rgba(201,168,76,0.12);"
  >
    <!-- Barra superior -->
    <div class="flex items-center justify-between px-4 py-3 border-b border-coro-gold/10 flex-shrink-0">
      <span class="text-coro-light/30 text-xs tracking-[0.25em] uppercase">Cartel</span>
      <button
        id="cerrar-cartel"
        class="text-coro-light/30 hover:text-coro-gold transition-colors"
        aria-label="Cerrar"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <!-- Imagen -->
    <div class="flex-1 min-h-0 flex items-center justify-center p-4">
      <img
        id="cartel-img"
        src=""
        alt="Cartel del concierto"
        class="max-w-full max-h-full object-contain"
      />
    </div>
  </div>
</div>

<!-- ─── Sección conciertos ─── -->
<section id="conciertos" class="py-24 px-4 bg-coro-gray">
  <div class="max-w-3xl mx-auto">

    <div class="reveal">
      <h2 class="section-title">Conciertos</h2>
    </div>

    <!-- Lista de conciertos próximos -->
    <div id="lista-proximos" class="reveal reveal-delay-1 divide-y divide-coro-gold/10">
      {conciertos.map((c) => (
        <div
          class="concierto-item flex items-center justify-between gap-6 py-6 first:pt-0 last:pb-0"
          data-fecha={c.fechaISO}
        >
          <div class="flex-1 min-w-0">
            <div class="flex items-baseline gap-3 flex-wrap mb-1">
              <span class="text-coro-gold text-sm">{c.fechaTexto}</span>
              {c.hora && <span class="text-coro-light/35 text-xs">{c.hora}</span>}
            </div>
            <a
              href={`https://maps.google.com/?q=${encodeURIComponent(c.lugar + ' ' + c.ciudad)}`}
              target="_blank"
              rel="noopener"
              class="group/maps inline-flex items-start gap-1.5"
            >
              <svg class="w-3 h-3 mt-1 flex-shrink-0 text-coro-light/25 group-hover/maps:text-coro-gold transition-colors" fill="currentColor" viewBox="0 0 24 24">
                <path fill-rule="evenodd" d="M11.54 22.351l.07.04.028.016a.76.76 0 0 0 .723 0l.028-.015.071-.041a16.975 16.975 0 0 0 1.144-.742 19.58 19.58 0 0 0 2.683-2.282c1.944-2.003 3.5-4.697 3.5-8.327a8.25 8.25 0 0 0-16.5 0c0 3.63 1.556 6.324 3.5 8.327a19.58 19.58 0 0 0 2.682 2.282 16.975 16.975 0 0 0 1.145.742ZM12 13.5a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" clip-rule="evenodd"/>
              </svg>
              <span>
                <p class="text-coro-light/75 text-sm underline underline-offset-2 decoration-coro-light/20 group-hover/maps:text-coro-gold group-hover/maps:decoration-coro-gold/40 transition-colors">{c.lugar}</p>
                <p class="text-coro-light/35 text-xs mt-0.5 group-hover/maps:text-coro-gold/60 transition-colors">{c.ciudad}</p>
              </span>
            </a>
          </div>
          <div class="flex-shrink-0 flex items-center gap-4">
            {c.cartel && (
              <button
                class="abrir-cartel-btn text-coro-light/25 hover:text-coro-gold transition-colors text-xs tracking-widest uppercase"
                data-cartel={c.cartel}
              >
                Cartel
              </button>
            )}
            {c.entradas
              ? <a href={c.entradas} target="_blank" rel="noopener" class="btn-primary text-xs px-4 py-2 whitespace-nowrap">Entradas</a>
              : <span class="text-coro-light/20 text-xs tracking-widest uppercase">Libre</span>
            }
          </div>
        </div>
      ))}
    </div>

    <!-- Sin conciertos próximos -->
    <div id="sin-conciertos" class="hidden text-center py-16 border border-coro-gold/15">
      <p class="text-coro-light/40 text-sm tracking-wide">Próximamente anunciaremos nuevas fechas.</p>
      <p class="text-coro-light/25 text-xs mt-1">Síguenos en redes para estar al día.</p>
    </div>

    <!-- Desplegable conciertos pasados -->
    <div id="bloque-pasados" class="hidden mt-10">
      <button
        id="toggle-pasados"
        class="flex items-center gap-2 text-coro-light/25 hover:text-coro-light/50 transition-colors text-xs tracking-[0.2em] uppercase mx-auto"
      >
        <span id="toggle-pasados-label">Conciertos anteriores</span>
        <svg id="toggle-pasados-chevron" class="w-3 h-3 transition-transform duration-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
        </svg>
      </button>

      <div id="lista-pasados" class="hidden mt-6 divide-y divide-coro-gold/8">
        {conciertos.map((c) => (
          <div
            class="concierto-pasado-item flex items-center justify-between gap-6 py-5"
            data-fecha={c.fechaISO}
          >
            <div class="flex-1 min-w-0">
              <div class="flex items-baseline gap-3 flex-wrap mb-1">
                <span class="text-coro-light/30 text-sm">{c.fechaTexto}</span>
                {c.hora && <span class="text-coro-light/20 text-xs">{c.hora}</span>}
              </div>
              <a
                href={`https://maps.google.com/?q=${encodeURIComponent(c.lugar + ' ' + c.ciudad)}`}
                target="_blank"
                rel="noopener"
                class="group/maps inline-flex items-start gap-1.5"
              >
                <svg class="w-3 h-3 mt-1 flex-shrink-0 text-coro-light/15 group-hover/maps:text-coro-light/40 transition-colors" fill="currentColor" viewBox="0 0 24 24">
                  <path fill-rule="evenodd" d="M11.54 22.351l.07.04.028.016a.76.76 0 0 0 .723 0l.028-.015.071-.041a16.975 16.975 0 0 0 1.144-.742 19.58 19.58 0 0 0 2.683-2.282c1.944-2.003 3.5-4.697 3.5-8.327a8.25 8.25 0 0 0-16.5 0c0 3.63 1.556 6.324 3.5 8.327a19.58 19.58 0 0 0 2.682 2.282 16.975 16.975 0 0 0 1.145.742ZM12 13.5a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" clip-rule="evenodd"/>
                </svg>
                <span>
                  <p class="text-coro-light/25 text-sm underline underline-offset-2 decoration-coro-light/10 group-hover/maps:text-coro-light/50 group-hover/maps:decoration-coro-light/25 transition-colors">{c.lugar}</p>
                  <p class="text-coro-light/15 text-xs mt-0.5 group-hover/maps:text-coro-light/30 transition-colors">{c.ciudad}</p>
                </span>
              </a>
            </div>
            <div class="flex-shrink-0 flex items-center gap-4">
              {c.cartel && (
                <button
                  class="abrir-cartel-btn text-coro-light/15 hover:text-coro-light/40 transition-colors text-xs tracking-widest uppercase"
                  data-cartel={c.cartel}
                >
                  Cartel
                </button>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<script is:inline define:vars={{ fechasJSON }}>
  document.addEventListener('DOMContentLoaded', () => {
    const today = new Date();
    today.setHours(0, 0, 0, 0);

    const fechas = JSON.parse(fechasJSON);

    // ── Separar próximos de pasados ──
    const proximosItems = document.querySelectorAll('#lista-proximos .concierto-item');
    const pasadosItems = document.querySelectorAll('#lista-pasados .concierto-pasado-item');
    let hayProximos = false;
    let hayPasados = false;

    proximosItems.forEach(item => {
      const [y, m, d] = item.dataset.fecha.split('-').map(Number);
      if (new Date(y, m - 1, d) < today) {
        item.classList.add('hidden');
      } else {
        hayProximos = true;
      }
    });

    pasadosItems.forEach(item => {
      const [y, m, d] = item.dataset.fecha.split('-').map(Number);
      if (new Date(y, m - 1, d) >= today) {
        item.classList.add('hidden');
      } else {
        hayPasados = true;
      }
    });

    if (!hayProximos) {
      document.getElementById('lista-proximos')?.classList.add('hidden');
      document.getElementById('sin-conciertos')?.classList.remove('hidden');
    }

    if (hayPasados) {
      document.getElementById('bloque-pasados')?.classList.remove('hidden');

      // Invertir orden: más reciente primero
      const listaPasadosEl = document.getElementById('lista-pasados');
      if (listaPasadosEl) {
        const visibles = [...listaPasadosEl.querySelectorAll('.concierto-pasado-item:not(.hidden)')];
        visibles.reverse().forEach(el => listaPasadosEl.appendChild(el));
      }
    }

    // ── Toggle conciertos pasados ──
    const toggleBtn = document.getElementById('toggle-pasados');
    const listaPasados = document.getElementById('lista-pasados');
    const chevron = document.getElementById('toggle-pasados-chevron');
    let pasadosAbiertos = false;

    toggleBtn?.addEventListener('click', () => {
      pasadosAbiertos = !pasadosAbiertos;
      listaPasados?.classList.toggle('hidden', !pasadosAbiertos);
      chevron?.classList.toggle('rotate-180', pasadosAbiertos);
    });

    // ── Lightbox cartel ──
    const modalCartel = document.getElementById('modal-cartel');
    const cartelImg = document.getElementById('cartel-img');
    const cerrarCartelBtn = document.getElementById('cerrar-cartel');

    function openCartel(src) {
      cartelImg.src = src;
      modalCartel.classList.remove('hidden');
      modalCartel.classList.add('flex');
      document.body.style.overflow = 'hidden';
      cerrarCartelBtn.focus();
    }

    function closeCartel() {
      modalCartel.classList.add('hidden');
      modalCartel.classList.remove('flex');
      document.body.style.overflow = '';
    }

    document.querySelectorAll('.abrir-cartel-btn').forEach(btn => {
      btn.addEventListener('click', () => openCartel(btn.dataset.cartel));
    });
    cerrarCartelBtn?.addEventListener('click', closeCartel);
    modalCartel?.addEventListener('click', e => { if (e.target === modalCartel) closeCartel(); });

    // ── Popup concierto próximo (< 7 días) ──
    const popup = document.getElementById('popup-concierto');
    const popupCerrar = document.getElementById('popup-cerrar');
    const popupFechaInfo = document.getElementById('popup-fecha-info');

    const SIETE_DIAS = 7 * 24 * 60 * 60 * 1000;
    let proxima = null;

    for (const f of fechas) {
      const [y, m, d] = f.fechaISO.split('-').map(Number);
      const diff = new Date(y, m - 1, d) - today;
      if (diff >= 0 && diff <= SIETE_DIAS) { proxima = f; break; }
    }

    if (proxima && popup && popupFechaInfo) {
      popupFechaInfo.innerHTML = `
        <p class="text-coro-gold text-sm">${proxima.fechaTexto}${proxima.hora ? ' · ' + proxima.hora : ''}</p>
        <p class="text-coro-light/70 text-sm mt-0.5">${proxima.lugar}</p>
        <p class="text-coro-light/35 text-xs">${proxima.ciudad}</p>
      `;
      setTimeout(() => {
        popup.classList.remove('hidden');
        popup.classList.add('flex');
      }, 1200);
    }

    function closePopup() {
      popup?.classList.add('hidden');
      popup?.classList.remove('flex');
      document.body.style.overflow = '';
    }

    popupCerrar?.addEventListener('click', closePopup);
    popup?.addEventListener('click', e => { if (e.target === popup) closePopup(); });
    document.getElementById('popup-ir')?.addEventListener('click', closePopup);

    // ── Escape ──
    document.addEventListener('keydown', e => {
      if (e.key !== 'Escape') return;
      if (!modalCartel.classList.contains('hidden')) closeCartel();
      else if (!popup.classList.contains('hidden')) closePopup();
    });
  });
</script>

<style>
  .concierto-item {
    transition: opacity 0.3s;
  }

  #popup-panel {
    animation: popup-enter 0.35s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  @keyframes popup-enter {
    from { opacity: 0; transform: translateY(16px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }
</style>
