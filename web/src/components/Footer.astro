---
const year = new Date().getFullYear();
---

<footer class="bg-coro-dark py-10 px-4 border-t border-coro-gold/20">
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6 text-center md:text-left">

    <div>
      <img src="/logo.png" alt="Coro Diatessaron" class="h-10 w-auto mx-auto md:mx-0 mb-3" />
      <p class="text-coro-light/60 text-xs">Molina de Segura, Murcia</p>
    </div>

    <nav aria-label="Navegación secundaria" class="flex flex-wrap justify-center gap-6 text-xs tracking-widest uppercase text-coro-light/60">
      <a href="#inicio" class="hover:text-coro-gold transition-colors">Inicio</a>
      <a href="#conciertos" class="hover:text-coro-gold transition-colors">Conciertos</a>
      <a href="#videos" class="hover:text-coro-gold transition-colors">Vídeos</a>
      <a href="#galeria" class="hover:text-coro-gold transition-colors">Galería</a>
      <a href="#nosotros" class="hover:text-coro-gold transition-colors">Nosotros</a>
      <a href="#contacto" class="hover:text-coro-gold transition-colors">Contacto</a>
    </nav>

    <p class="text-coro-light/50 text-xs">
      © {year} Coro Diatessaron
    </p>

  </div>
</footer>
