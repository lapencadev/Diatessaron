---
// Añade tus mejores fotos aquí. Sin categorías — solo una selección curada.
const fotos = [
  { src: '/images/galeria/foto8.jpg', alt: 'Coro Diatessaron en concierto — iluminación azul' },
  { src: '/images/galeria/foto5.jpg', alt: 'Concierto Destellos — Northern Lights' },
  { src: '/images/galeria/foto7.jpg', alt: 'Coro Diatessaron en escena' },
  { src: '/images/galeria/foto1.jpg', alt: 'Concierto con orquesta en iglesia' },
  { src: '/images/galeria/foto2.jpg', alt: 'Actuación en iglesia' },
  { src: '/images/galeria/foto3.jpg', alt: 'Concierto de Navidad en el teatro' },
  { src: '/images/galeria/foto4.jpg', alt: 'Coro Diatessaron entre bastidores' },
  { src: '/images/galeria/foto6.jpg', alt: 'Foto de grupo del coro' },
];
---

<section id="galeria" class="py-24 px-4 bg-coro-gray overflow-hidden">
  <div class="max-w-6xl mx-auto">

    <div class="reveal">
      <h2 class="section-title">Galería</h2>
      <div class="section-divider"></div>
    </div>

    <div class="reveal reveal-delay-1">
      <!-- Swiper carousel -->
      <div class="swiper galeria-swiper">
        <div class="swiper-wrapper">
          {fotos.map(foto => (
            <div class="swiper-slide">
              <div class="relative overflow-hidden aspect-[4/3] group cursor-pointer">
                <img
                  src={foto.src}
                  alt={foto.alt}
                  loading="lazy"
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4">
                  <span class="text-coro-light text-sm font-light" style="font-family: 'Cormorant Garamond', serif;">{foto.alt}</span>
                </div>
              </div>
            </div>
          ))}
        </div>
        <div class="swiper-pagination mt-6"></div>
        <div class="swiper-button-prev"></div>
        <div class="swiper-button-next"></div>
      </div>
    </div>

  </div>
</section>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" is:inline></script>
<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    new Swiper('.galeria-swiper', {
      slidesPerView: 1,
      spaceBetween: 16,
      loop: true,
      autoplay: { delay: 4000, disableOnInteraction: false, pauseOnMouseEnter: true, pauseOnFocusLoss: true },
      pagination: { el: '.swiper-pagination', clickable: true },
      navigation: { nextEl: '.swiper-button-next', prevEl: '.swiper-button-prev' },
      keyboard: { enabled: true },
      a11y: {
        prevSlideMessage: 'Foto anterior',
        nextSlideMessage: 'Foto siguiente',
        paginationBulletMessage: 'Ir a la foto {{index}}',
      },
      breakpoints: {
        640:  { slidesPerView: 2 },
        1024: { slidesPerView: 3 },
      },
    });
  });
</script>
