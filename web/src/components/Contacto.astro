---
const EMAILJS_SERVICE_ID = import.meta.env.PUBLIC_EMAILJS_SERVICE_ID;
const EMAILJS_TEMPLATE_ID = import.meta.env.PUBLIC_EMAILJS_TEMPLATE_ID;
const EMAILJS_PUBLIC_KEY = import.meta.env.PUBLIC_EMAILJS_PUBLIC_KEY;
---

<section id="contacto" class="py-24 px-4 bg-coro-dark">
  <div class="max-w-2xl mx-auto">

    <div class="reveal">
      <h2 class="section-title">Contacto</h2>
      <div class="section-divider"></div>
    </div>

    <p class="text-coro-light/60 mb-10 leading-relaxed">
      ¿Quieres contratarnos para un evento, tienes alguna pregunta, o simplemente quieres unirte al coro?
      Escríbenos y te responderemos lo antes posible.
    </p>

    <!-- Netlify Forms: el atributo "netlify" lo detecta Netlify automáticamente en el build -->
    <form
      name="contacto"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      class="space-y-6"
      id="contact-form"
      data-ejs-service={EMAILJS_SERVICE_ID}
      data-ejs-template={EMAILJS_TEMPLATE_ID}
      data-ejs-key={EMAILJS_PUBLIC_KEY}
    >
      <!-- Honeypot anti-spam (oculto) -->
      <input type="hidden" name="form-name" value="contacto" />
      <p class="hidden">
        <label>No rellenar: <input name="bot-field" /></label>
      </p>

      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <label for="nombre" class="block text-xs tracking-widest uppercase text-coro-light/60 mb-2">Nombre *</label>
          <input
            type="text"
            id="nombre"
            name="nombre"
            required
            class="w-full bg-coro-gray border border-coro-gold/20 text-coro-light px-4 py-3 focus:outline-none focus:border-coro-gold transition-colors rounded-sm"
            placeholder="Tu nombre"
          />
        </div>
        <div>
          <label for="email" class="block text-xs tracking-widest uppercase text-coro-light/60 mb-2">Email *</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full bg-coro-gray border border-coro-gold/20 text-coro-light px-4 py-3 focus:outline-none focus:border-coro-gold transition-colors rounded-sm"
            placeholder="tu@email.com"
          />
        </div>
      </div>

      <div>
        <label for="asunto" class="block text-xs tracking-widest uppercase text-coro-light/60 mb-2">Asunto</label>
        <select
          id="asunto"
          name="asunto"
          class="w-full bg-coro-gray border border-coro-gold/20 text-coro-light px-4 py-3 focus:outline-none focus:border-coro-gold transition-colors rounded-sm"
        >
          <option value="general">Consulta general</option>
          <option value="contratacion">Contratación / Actuación</option>
          <option value="unirse">Quiero unirme al coro</option>
          <option value="prensa">Prensa / Medios</option>
          <option value="otro">Otro</option>
        </select>
      </div>

      <div>
        <label for="mensaje" class="block text-xs tracking-widest uppercase text-coro-light/60 mb-2">Mensaje *</label>
        <textarea
          id="mensaje"
          name="mensaje"
          required
          rows="5"
          class="w-full bg-coro-gray border border-coro-gold/20 text-coro-light px-4 py-3 focus:outline-none focus:border-coro-gold transition-colors rounded-sm resize-none"
          placeholder="Escribe tu mensaje aquí..."
        ></textarea>
      </div>

      <button
        type="submit"
        class="btn-primary w-full md:w-auto"
      >
        Enviar mensaje
      </button>

    </form>

  </div>
</section>

<!-- Toast de notificación -->
<div id="toast" class="fixed bottom-8 left-1/2 -translate-x-1/2 z-50 flex items-center gap-3 px-6 py-4 rounded-sm shadow-lg border opacity-0 pointer-events-none transition-all duration-300 translate-y-4" role="alert">
  <span id="toast-icon" class="text-xl"></span>
  <span id="toast-msg" class="text-sm tracking-wide"></span>
</div>

<script>
  import emailjs from '@emailjs/browser';

  const form = document.getElementById('contact-form') as HTMLFormElement;
  const toast = document.getElementById('toast')!;
  const toastIcon = document.getElementById('toast-icon')!;
  const toastMsg = document.getElementById('toast-msg')!;

  emailjs.init(form.dataset.ejsKey!);

  function showToast(type: 'success' | 'error', message: string) {
    if (type === 'success') {
      toast.className = toast.className.replace(/bg-\S+|border-\S+|text-\S+/g, '');
      toast.classList.add('bg-coro-dark', 'border-coro-gold/40', 'text-coro-light');
      toastIcon.textContent = '✓';
      toastIcon.className = 'text-xl text-coro-gold';
    } else {
      toast.classList.add('bg-coro-dark', 'border-red-500/40', 'text-coro-light');
      toastIcon.textContent = '✕';
      toastIcon.className = 'text-xl text-red-400';
    }
    toastMsg.textContent = message;
    toast.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-4');
    toast.classList.add('opacity-100', 'translate-y-0');

    setTimeout(() => {
      toast.classList.add('opacity-0', 'pointer-events-none', 'translate-y-4');
      toast.classList.remove('opacity-100', 'translate-y-0');
    }, 5000);
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Enviando...';

    try {
      const data = new FormData(form);
      await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(data as unknown as Record<string, string>).toString(),
      });

      await emailjs.sendForm(form.dataset.ejsService!, form.dataset.ejsTemplate!, form);

      form.reset();
      showToast('success', 'Mensaje enviado correctamente. ¡Gracias, te responderemos pronto!');
    } catch {
      showToast('error', 'Error al enviar. Por favor, inténtalo de nuevo.');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Enviar mensaje';
    }
  });
</script>
