---

<section id="historial" class="py-24 px-4 bg-coro-dark overflow-hidden">
  <div class="max-w-5xl mx-auto">

    <div class="reveal">
      <h2 class="section-title">Historial de programas</h2>
      <div class="section-divider"></div>
    </div>
    <p class="text-coro-light/50 text-sm mb-20 reveal reveal-delay-1">15 años de música, voces y momentos compartidos.</p>

    <!-- ── DESKTOP TIMELINE ── -->
    <div class="hidden md:block relative" id="tl-desktop">

      <!-- Línea vertical central -->
      <div class="absolute left-1/2 -translate-x-1/2 top-0 bottom-0 w-px"
           style="background: linear-gradient(to bottom, transparent, rgba(201,168,76,0.3) 5%, rgba(201,168,76,0.3) 95%, transparent);"></div>

      {años.map((a, i) => {
        const isLeft = i % 2 === 0;
        const prog = a.programa;
        return (
          <div class="tl-item" style="margin-bottom: 2rem;">
            <div class="relative flex items-start">

            <!-- Slot izquierdo (46%) -->
            <div class="w-[46%] flex justify-end pr-0">
              {isLeft && (
                <div class="tl-card w-full flex items-start gap-0">
                  <button class="tl-btn flex-1 text-right group" aria-expanded="false" data-idx={`d-${i}`}>
                    <div class="py-3 px-4 border border-transparent hover:border-coro-gold/15 hover:bg-white/[0.02] transition-all duration-300 rounded-sm">
                      <div class="flex items-baseline justify-end gap-3">
                        <span class={`font-serif leading-snug ${a.destacado ? 'text-coro-light text-lg' : 'text-coro-light/65 text-base'}`}>{prog?.titulo}</span>
                        <span class={`font-serif tabular-nums flex-shrink-0 ${a.destacado ? 'text-coro-gold text-2xl' : 'text-coro-gold/45 text-lg'}`}>{a.año}</span>
                      </div>
                      {prog?.subtitulo && (
                        <p class="text-coro-gold/55 text-xs mt-0.5 text-right">{prog.subtitulo}</p>
                      )}
                      {a.otros.length > 0 && (
                        <p class="text-coro-light/25 text-[10px] mt-1 text-right tracking-wide">+ {a.otros.length} evento{a.otros.length > 1 ? 's' : ''}</p>
                      )}
                    </div>
                  </button>
                </div>
              )}
            </div>

            <!-- Centro (8%): rama + punto -->
            <div class="w-[8%] flex-shrink-0 relative flex items-start justify-center" style="min-height: 3rem;">
              {isLeft && (
                <div class="absolute h-px bg-coro-gold/30"
                     style="top: 1.5rem; left: 0; right: 50%;"></div>
              )}
              {!isLeft && (
                <div class="absolute h-px bg-coro-gold/30"
                     style="top: 1.5rem; left: 50%; right: 0;"></div>
              )}
              <div class={`w-2.5 h-2.5 rounded-full border-2 z-10 flex-shrink-0 transition-all duration-300 ${a.destacado ? 'bg-coro-gold border-coro-gold shadow-[0_0_10px_rgba(201,168,76,0.4)]' : 'bg-coro-dark border-coro-gold/40'}`}
                   style="margin-top: 1.175rem;">
              </div>
            </div>

            <!-- Slot derecho (46%) -->
            <div class="w-[46%] pl-0">
              {!isLeft && (
                <button class="tl-btn w-full text-left group" aria-expanded="false" data-idx={`d-${i}`}>
                  <div class="py-3 px-4 border border-transparent hover:border-coro-gold/15 hover:bg-white/[0.02] transition-all duration-300 rounded-sm">
                    <div class="flex items-baseline gap-3">
                      <span class={`font-serif tabular-nums flex-shrink-0 ${a.destacado ? 'text-coro-gold text-2xl' : 'text-coro-gold/45 text-lg'}`}>{a.año}</span>
                      <span class={`font-serif leading-snug ${a.destacado ? 'text-coro-light text-lg' : 'text-coro-light/65 text-base'}`}>{prog?.titulo}</span>
                    </div>
                    {prog?.subtitulo && (
                      <p class="text-coro-gold/55 text-xs mt-0.5">{prog.subtitulo}</p>
                    )}
                    {a.otros.length > 0 && (
                      <p class="text-coro-light/25 text-[10px] mt-1 tracking-wide">+ {a.otros.length} evento{a.otros.length > 1 ? 's' : ''}</p>
                    )}
                  </div>
                </button>
              )}
            </div>

            </div>

          <!-- Detalle expandible (desktop) -->
          <div id={`tl-detail-d-${i}`} class="hidden tl-detail">
            <div class="flex">
              <div class="w-[46%]"></div>
              <div class="w-[8%]"></div>
              <div class="w-[46%]">
                {!isLeft && (
                  <div class="px-4 pt-3 pb-4 border-x border-b border-coro-gold/10 bg-white/[0.015]">
                    {prog && (
                      <div>
                        <p class="text-coro-light/35 text-xs mb-2">{prog.lugar}</p>
                        <p class="text-coro-light/60 text-sm leading-relaxed">{prog.descripcion}</p>
