                </div>
              )}
            </div>
          </div>
        );
      })}
    </div>

  </div>
</section>

<script>
  // Expand/collapse on click
  document.querySelectorAll('.tl-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const idx = (btn as HTMLElement).dataset.idx!;
      const detailD = document.getElementById(`tl-detail-d-${idx.replace(/^[dm]-/, '')}`);
      const detailM = document.getElementById(`tl-detail-m-${idx.replace(/^[dm]-/, '')}`);
      const target = idx.startsWith('d-') ? detailD : detailM;
      if (!target) return;

      const isOpen = !target.classList.contains('hidden');
      target.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', String(!isOpen));
    });
  });

  // Scroll reveal: slide in from sides
  const isMobile = () => window.innerWidth < 768;
  const allItems = document.querySelectorAll('.tl-item, .tl-item-m');

  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const el = entry.target as HTMLElement;
        el.style.opacity = '1';
        el.style.transform = 'translateX(0)';
        observer.unobserve(el);
      }
    });
  }, { threshold: 0.05, rootMargin: '0px 0px -30px 0px' });

  allItems.forEach((el, i) => {
    const htmlEl = el as HTMLElement;
    const isLeft = i % 2 === 0;
    const offset = isMobile() ? '-16px' : (isLeft ? '-24px' : '24px');
    htmlEl.style.opacity = '0';
    htmlEl.style.transform = `translateX(${offset})`;
    htmlEl.style.transition = `opacity 0.5s ease ${i * 0.045}s, transform 0.5s ease ${i * 0.045}s`;
    observer.observe(el);
  });
</script>
