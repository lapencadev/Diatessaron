                          <div class="flex gap-5 mt-3">
                            {prog.video && <a href={prog.video} target="_blank" rel="noopener" class="text-coro-gold text-xs hover:underline uppercase tracking-wide flex items-center gap-1"><svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>Vídeo</a>}
                            {prog.dossier && <a href={prog.dossier} target="_blank" rel="noopener" class="text-coro-light/40 hover:text-coro-gold text-xs uppercase tracking-wide transition-colors">Dossier</a>}
                          </div>
                        )}
                      </div>
                    )}
                    {a.otros.length > 0 && (
                      <div class={prog ? 'mt-4 pt-3 border-t border-coro-gold/10' : ''}>
                        <p class="text-coro-light/30 text-[10px] uppercase tracking-widest mb-3">También en {a.año}</p>
                        <div class="space-y-3">
                          {a.otros.map(ev => (
                            <div class="pl-2 border-l border-coro-gold/20">
                              <p class="text-coro-gold/50 text-[10px] uppercase tracking-widest mb-0.5">
                                {ev.tipo === 'premio' ? '★ Premio' : '♦ Colaboración'}
                              </p>
                              <p class="text-coro-light/75 text-sm font-serif">{ev.titulo}</p>
                              {ev.subtitulo && <p class="text-coro-gold/45 text-xs mt-0.5">{ev.subtitulo}</p>}
                              {ev.descripcion && <p class="text-coro-light/50 text-xs leading-relaxed mt-1">{ev.descripcion}</p>}
                              {(ev.video || ev.dossier) && (
                                <div class="flex gap-4 mt-1.5">
                                  {ev.video && <a href={ev.video} target="_blank" rel="noopener" class="text-coro-gold text-xs hover:underline uppercase tracking-wide">▶ Vídeo</a>}
                                  {ev.dossier && <a href={ev.dossier} target="_blank" rel="noopener" class="text-coro-light/40 hover:text-coro-gold text-xs uppercase tracking-wide transition-colors">Dossier</a>}
                                </div>
                              )}
                            </div>
                          ))}
                        </div>
                      </div>
                    )}
                  </div>
                )}
              </div>
            </div>
            <div class="flex">
              <div class="w-[46%]">
                {isLeft && (
                  <div class="px-4 pt-3 pb-4 border-x border-b border-coro-gold/10 bg-white/[0.015] text-right">
                    {prog && (
                      <div>
                        <p class="text-coro-light/35 text-xs mb-2">{prog.lugar}</p>
                        <p class="text-coro-light/60 text-sm leading-relaxed">{prog.descripcion}</p>
                        {(prog.video || prog.dossier) && (
                          <div class="flex gap-5 mt-3 justify-end">
                            {prog.video && <a href={prog.video} target="_blank" rel="noopener" class="text-coro-gold text-xs hover:underline uppercase tracking-wide flex items-center gap-1"><svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>Vídeo</a>}
                            {prog.dossier && <a href={prog.dossier} target="_blank" rel="noopener" class="text-coro-light/40 hover:text-coro-gold text-xs uppercase tracking-wide transition-colors">Dossier</a>}
                          </div>
                        )}
                      </div>
                    )}
                    {a.otros.length > 0 && (
                      <div class={prog ? 'mt-4 pt-3 border-t border-coro-gold/10' : ''}>
                        <p class="text-coro-light/30 text-[10px] uppercase tracking-widest mb-3">También en {a.año}</p>
                        <div class="space-y-3">
                          {a.otros.map(ev => (
                            <div class="pr-2 border-r border-coro-gold/20">
                              <p class="text-coro-gold/50 text-[10px] uppercase tracking-widest mb-0.5">
                                {ev.tipo === 'premio' ? '★ Premio' : '♦ Colaboración'}
                              </p>
                              <p class="text-coro-light/75 text-sm font-serif">{ev.titulo}</p>
                              {ev.subtitulo && <p class="text-coro-gold/45 text-xs mt-0.5">{ev.subtitulo}</p>}
                              {ev.descripcion && <p class="text-coro-light/50 text-xs leading-relaxed mt-1">{ev.descripcion}</p>}
                              {(ev.video || ev.dossier) && (
                                <div class="flex gap-4 mt-1.5 justify-end">
                                  {ev.video && <a href={ev.video} target="_blank" rel="noopener" class="text-coro-gold text-xs hover:underline uppercase tracking-wide">▶ Vídeo</a>}
                                  {ev.dossier && <a href={ev.dossier} target="_blank" rel="noopener" class="text-coro-light/40 hover:text-coro-gold text-xs uppercase tracking-wide transition-colors">Dossier</a>}
                                </div>
                              )}
                            </div>
                          ))}
                        </div>
                      </div>
                    )}
                  </div>
                )}
              </div>
              <div class="w-[8%]"></div>
              <div class="w-[46%]"></div>
            </div>
          </div>
          </div>
        );
      })}
    </div>

    <!-- ── MOBILE TIMELINE ── -->
    <div class="md:hidden relative pl-8" id="tl-mobile">
      <!-- Línea izquierda -->
      <div class="absolute left-3 top-0 bottom-0 w-px"
           style="background: linear-gradient(to bottom, transparent, rgba(201,168,76,0.3) 5%, rgba(201,168,76,0.3) 95%, transparent);"></div>

      {años.map((a, i) => {
        const prog = a.programa;
        return (
          <div class="tl-item-m relative mb-6">
            <!-- Punto -->
            <div class={`absolute -left-[1.5625rem] top-[1.2rem] w-2.5 h-2.5 rounded-full border-2 z-10
              ${a.destacado ? 'bg-coro-gold border-coro-gold' : 'bg-coro-dark border-coro-gold/40'}`}></div>

            <!-- Card -->
            <button class="tl-btn w-full text-left" aria-expanded="false" data-idx={`m-${i}`}>
              <div class="py-2.5 px-3 border border-transparent hover:border-coro-gold/15 hover:bg-white/[0.02] transition-all duration-300">
                <div class="flex items-baseline gap-2.5">
                  <span class={`font-serif tabular-nums flex-shrink-0 ${a.destacado ? 'text-coro-gold text-xl' : 'text-coro-gold/45 text-lg'}`}>{a.año}</span>
                  <span class={`font-serif leading-snug ${a.destacado ? 'text-coro-light text-base' : 'text-coro-light/65 text-sm'}`}>{prog?.titulo}</span>
                  {(a.otros.some(e => e.tipo === 'premio') || prog?.subtitulo?.includes('Premio')) && (
                    <span class="text-coro-gold text-xs flex-shrink-0">★</span>
                  )}
                </div>
                {prog?.subtitulo && <p class="text-coro-gold/55 text-xs mt-0.5 pl-0.5">{prog.subtitulo}</p>}
                {a.otros.length > 0 && (
                  <p class="text-coro-light/25 text-[10px] mt-0.5 pl-0.5 tracking-wide">+ {a.otros.length} evento{a.otros.length > 1 ? 's' : ''}</p>
