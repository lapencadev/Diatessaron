                </div>
                {prog?.fecha && <p class="text-coro-light/65 text-xs mt-0.5 pl-0.5">{prog.fecha}</p>}
                {prog?.subtitulo && <p class="text-coro-gold/85 text-xs mt-0.5 pl-0.5">{prog.subtitulo}</p>}
                {a.otros.length > 0 && (
                  <p class="text-coro-light/60 text-xs mt-0.5 pl-0.5 tracking-wide">+ {a.otros.length} evento{a.otros.length > 1 ? 's' : ''}</p>
                )}
              </div>
            </button>

            <!-- Detalle expandible -->
            <div id={`tl-detail-m-${i}`} class="hidden tl-detail px-3 pt-3 pb-3 border-x border-b border-coro-gold/10 bg-white/[0.015]">
              {prog && (
                <div>
                  {prog.fecha && <p class="text-coro-light/60 text-xs mb-1">{prog.fecha}</p>}
                  <p class="text-coro-light/60 text-xs mb-1.5">{prog.lugar}</p>
                  <p class="text-coro-light/60 text-sm leading-relaxed">{prog.descripcion}</p>
                  {(prog.video || prog.dossier) && (
                    <div class="flex gap-4 mt-2.5">
                      {prog.video && <a href={prog.video} target="_blank" rel="noopener" class="text-coro-gold text-xs hover:underline uppercase tracking-wide">▶ Vídeo</a>}
                      {prog.dossier && <a href={prog.dossier} target="_blank" rel="noopener" class="text-coro-light/40 hover:text-coro-gold text-xs uppercase tracking-wide transition-colors">Dossier</a>}
                    </div>
                  )}
                </div>
              )}
              {a.otros.length > 0 && (
                <div class={prog ? 'mt-3 pt-2.5 border-t border-coro-gold/10' : ''}>
                  <p class="text-coro-light/60 text-[10px] uppercase tracking-widest mb-2.5">También en {a.año}</p>
                  <div class="space-y-2.5">
                    {a.otros.map(ev => (
                      <div class="pl-2 border-l border-coro-gold/20">
                        <p class="text-coro-gold/80 text-[10px] uppercase tracking-widest mb-0.5">
                          <span aria-hidden="true">{tipoIcon(ev.tipo)} </span>{tipoLabel(ev.tipo)}
                        </p>
                        <p class="text-coro-light/75 text-sm font-serif">{ev.titulo}</p>
                        {ev.fecha && <p class="text-coro-light/55 text-[10px] mt-0.5">{ev.fecha}</p>}
                        {ev.subtitulo && <p class="text-coro-gold/75 text-xs mt-0.5">{ev.subtitulo}</p>}
                        {ev.descripcion && <p class="text-coro-light/50 text-xs leading-relaxed mt-1">{ev.descripcion}</p>}
                        {(ev.video || ev.dossier) && (
                          <div class="flex gap-4 mt-1.5">
                            {ev.video && <a href={ev.video} target="_blank" rel="noopener" class="text-coro-gold text-xs hover:underline uppercase tracking-wide">▶ Vídeo</a>}
                            {ev.dossier && <a href={ev.dossier} target="_blank" rel="noopener" class="text-coro-light/40 hover:text-coro-gold text-xs uppercase tracking-wide transition-colors">Dossier</a>}
                          </div>
                        )}
                      </div>
                    ))}
                  </div>
                </div>
              )}
            </div>
          </div>
        );
      })}
    </div>

  </div>
</section>

<script>
  // Expand/collapse on click
  document.querySelectorAll('.tl-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const idx = (btn as HTMLElement).dataset.idx!;
      const detailD = document.getElementById(`tl-detail-d-${idx.replace(/^[dm]-/, '')}`);
      const detailM = document.getElementById(`tl-detail-m-${idx.replace(/^[dm]-/, '')}`);
      const target = idx.startsWith('d-') ? detailD : detailM;
      if (!target) return;

      const isOpen = !target.classList.contains('hidden');
      target.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', String(!isOpen));
    });
  });

  // Scroll reveal: slide in from sides
  const isMobile = () => window.innerWidth < 768;
  const allItems = document.querySelectorAll('.tl-item, .tl-item-m');

  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const el = entry.target as HTMLElement;
        el.style.opacity = '1';
        el.style.transform = 'translateX(0)';
        observer.unobserve(el);
      }
    });
  }, { threshold: 0.05, rootMargin: '0px 0px -30px 0px' });

  allItems.forEach((el, i) => {
    const htmlEl = el as HTMLElement;
    const isLeft = i % 2 === 0;
    const offset = isMobile() ? '-16px' : (isLeft ? '-24px' : '24px');
    htmlEl.style.opacity = '0';
    htmlEl.style.transform = `translateX(${offset})`;
    htmlEl.style.transition = `opacity 0.5s ease ${i * 0.045}s, transform 0.5s ease ${i * 0.045}s`;
    observer.observe(el);
  });
</script>
