---
// heroImage: foto de fondo del hero. Cambia aquí si quieres otra.
const heroImage = '/images/galeria/foto8.jpg';
---

<section
  id="inicio"
  class="relative min-h-screen flex items-center justify-center overflow-hidden"
>
  <!-- Foto de fondo -->
  <div class="absolute inset-0">
    <img
      src={heroImage}
      alt="Coro Diatessaron en concierto"
      class="w-full h-full object-cover object-center"
      style="object-position: center 30%;"
    />
  </div>

  <!-- Capas de oscurecimiento: gradiente superior (para nav) + inferior (para texto) + general -->
  <div class="absolute inset-0 bg-coro-dark/55" aria-hidden="true"></div>
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: linear-gradient(to bottom, rgba(13,13,13,0.7) 0%, transparent 25%, transparent 55%, rgba(13,13,13,0.85) 100%);"
    aria-hidden="true"
  ></div>

  <!-- Contenido central -->
  <div class="relative z-10 text-center px-6 max-w-4xl mx-auto">

    <!-- Nombre del coro — tipografía como protagonista -->
    <div id="hero-eyebrow" class="opacity-0 translate-y-4 transition-all duration-700 ease-out mb-4">
      <span class="text-coro-gold text-xs md:text-sm tracking-[0.4em] uppercase font-light">
        Molina de Segura &nbsp;·&nbsp; Murcia
      </span>
    </div>

    <div id="hero-title" class="opacity-0 translate-y-6 transition-all duration-1000 ease-out mb-6">
      <h1
        class="text-6xl sm:text-7xl md:text-8xl lg:text-9xl font-light text-white leading-none"
        style="font-family: 'Cormorant Garamond', Georgia, serif; text-shadow: 0 2px 40px rgba(0,0,0,0.8);"
      >
        Coro
      </h1>
      <h1
        class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-light leading-none"
        style="font-family: 'Cormorant Garamond', Georgia, serif; color: #C9A84C; text-shadow: 0 2px 40px rgba(0,0,0,0.8);"
      >
        Diatessaron
      </h1>
    </div>

    <div id="hero-desc" class="opacity-0 translate-y-4 transition-all duration-700 ease-out mb-10">
      <p
        class="text-white/50 text-base md:text-lg font-light max-w-sm mx-auto"
        style="font-family: 'Cormorant Garamond', Georgia, serif; font-style: italic;"
      >
        Dirigido por <span class="text-coro-gold/80 not-italic">Tomeu Quetgles</span>
      </p>
    </div>

    <div id="hero-ctas" class="opacity-0 translate-y-4 transition-all duration-700 ease-out flex flex-col sm:flex-row gap-4 justify-center">
      <a href="#conciertos" class="btn-primary">Próximos conciertos</a>
      <a href="#videos" class="btn-outline">Ver vídeos</a>
    </div>

  </div>

  <!-- Flecha scroll -->
  <a
    id="hero-arrow"
    href="#conciertos"
    class="absolute bottom-10 left-1/2 -translate-x-1/2 opacity-0 transition-opacity duration-1000 text-white/30 hover:text-coro-gold"
    aria-label="Scroll hacia abajo"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 9l-7 7-7-7" />
    </svg>
  </a>
</section>

<script>
  requestAnimationFrame(() => {
    setTimeout(() => document.getElementById('hero-eyebrow')?.classList.remove('opacity-0', 'translate-y-4'), 200);
    setTimeout(() => document.getElementById('hero-title')?.classList.remove('opacity-0', 'translate-y-6'), 400);
    setTimeout(() => document.getElementById('hero-desc')?.classList.remove('opacity-0', 'translate-y-4'), 700);
    setTimeout(() => document.getElementById('hero-ctas')?.classList.remove('opacity-0', 'translate-y-4'), 900);
    setTimeout(() => document.getElementById('hero-arrow')?.classList.remove('opacity-0'), 1400);
  });

  // Scroll reveal global
  const observer = new IntersectionObserver(
    (entries) => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } }),
    { threshold: 0.12 }
  );
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>
